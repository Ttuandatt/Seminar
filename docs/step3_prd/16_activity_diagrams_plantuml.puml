' ============================================================
' UC-01: Login
' ============================================================
@startuml
start

:User opens Login page;
:Show form with Email + Password;

repeat
  :Enter email/password and click "Login";
  :Validate email format and non-empty password;
  if (Format valid?) then (No)
    :Show format error;
  else (Yes)
    repeat
      :Lookup user by email and compare bcrypt password;
      if (Credentials correct?) then (No)
        :Show "Incorrect email or password";
      else (Yes)
        if (Account locked?) then (Yes)
          :Show "Account has been locked. Contact administrator.";
          stop
        else
          if (≥5 failed attempts in 15m?) then (Yes)
            :Temporarily lock account and notify;
            stop
          else (No)
            :Issue JWT access token (15m)\nand refresh token (7d, Redis);
            :Redirect by role\n(Admin → Dashboard,\nShop Owner → Portal,\nTourist → App);
            stop
          endif
        endif
      endif
    repeat while (Retry lookup?) is (Yes)
  endif
repeat while (Retry input?) is (Yes)

@enduml


' ============================================================
' UC-02: Register
' ============================================================
@startuml
start

:User opens Registration page;
:Show form: email, password, confirm password,\nfullName, select role (Tourist / Shop Owner);

repeat
  :Fill in form fields;

  if (Selected role?) then (Shop Owner)
    :Enter additional shopName + phone;
  else (Tourist)
  endif

  :Click "Register";
  :Validate input data;

  if (All validations pass?) then (No)
    split
      :Email already exists\n"This email is already registered" [E1];
    split again
      :Password < 8 chars or\nmissing uppercase/digit [E2];
    split again
      :Password != Confirm Password\n"Passwords do not match" [E3];
    end split
  else (Yes)
  endif
repeat while (Validation failed?) is (Yes)

fork
  :Hash password with bcrypt (cost 12);
fork again
  :Prepare role-specific data;
end fork

:Create User record in database;

if (Selected role?) then (Shop Owner [A1])
  :Create ShopOwner record linked to User;
else (Tourist)
endif

fork
  :Issue JWT tokens (access + refresh);
fork again
  :Auto-login for Actor;
end fork

if (Role?) then (Shop Owner)
  :Redirect to Shop Owner Portal;
else (Tourist)
  :Redirect to Map screen;
endif

stop

@enduml


' ============================================================
' UC-03: Logout
' ============================================================
@startuml
start

:User clicks "Logout" button;
:Show confirmation "Do you want to logout?";

if (Confirm?) then (No [A1])
  :Cancel — stay logged in;
  stop
else (Yes)
endif

fork
  :Call API logout:\ndelete refresh token from Redis;
fork again
  :Clear tokens from client storage\n(localStorage / AsyncStorage);
end fork

:Redirect to login page;

stop

@enduml


' ============================================================
' UC-04: Forgot Password
' ============================================================
@startuml
start

:User clicks "Forgot Password" on login page;
:Show email input form;

:Enter email and click "Send";
:Check if email exists in system;

if (Email exists?) then (No [E1])
  :Show success message anyway\n(prevent info leakage);
  stop
else (Yes)
endif

fork
  :Generate reset token (UUID, expires 15 min);
fork again
  :Store token in database;
end fork

:Send email with reset link\nhttps://app/reset-password?token=<uuid>;
:Show "Password reset email sent";

:User opens link from email;
:Enter new password;

if (Token valid & not expired?) then (No [E2])
  :Show "Link expired. Please request again.";
  stop
else (Yes)
endif

fork
  :Hash new password;
fork again
  :Delete used token;
end fork

:Update password in database;
:Show "Password reset successful";
:Redirect to login page;

stop

@enduml


