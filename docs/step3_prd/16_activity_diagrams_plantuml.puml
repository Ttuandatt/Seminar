@startuml
start

:Tourist taps heart icon on POI detail (UC-51);

if (Tourist logged in?) then (No [E1])
  :Show "Login to save favorites";
  :Redirect to login screen;
  stop
else (Yes)
endif

:Check current favorite status;

if (Already favorited?) then (Yes → Remove)
  :DELETE /tourist/favorites/{poiId};
  :Delete Favorite record;
  :Icon changes to empty heart;
else (No → Add)
  :POST /tourist/favorites/{poiId};
  :Create Favorite record;
  :Icon changes to filled heart;
endif

stop

@enduml


' ============================================================
' UC-56: View Visit History (Tourist)
' ============================================================
@startuml
start

:Tourist opens "History" tab;

if (Tourist logged in?) then (No [E1])
  :Show "Login to view history";
  stop
else (Yes)
endif

:Call API GET /tourist/history;

if (History exists?) then (No [E2])
  :Show empty state "No visit history yet";
  stop
else (Yes)
endif

:Display ViewHistory list:\nPOI image, name, datetime, triggerType, audioPlayed icon;

:Tap on a history item;
:Navigate to POI detail (UC-51);

stop

@enduml


' ============================================================
' UC-60: View Tour List (Tourist)
' ============================================================
@startuml
start

:Tourist opens "Tours" tab;
:Call API GET /public/tours (status = ACTIVE);

if (ACTIVE tours exist?) then (No [E1])
  :Show "No tours available. Check back later!";
  stop
else (Yes)
endif

:Display tour list: name, POI count, thumbnail;

:Tap on a tour;
:Navigate to UC-61 (View Tour Detail);

stop

@enduml


' ============================================================
' UC-61: View Tour Detail (Tourist)
' ============================================================
@startuml
start

:Tourist selects tour from list (UC-60);
:Call API GET /public/tours/:id (with POI list);

fork
  :Display tour name and description;
fork again
  :Display map with POI markers and polyline route;
fork again
  :Display POI list by order\nwith number, name, estimated distance;
end fork

:Tap on a POI in tour;
:Navigate to UC-51 (View POI Detail);

stop

@enduml


