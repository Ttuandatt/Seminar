if (Add EN/ZH content?) then (Yes [A1])
  :Enter EN and/or ZH name + description;
else (No)
endif

if (Action?) then (Cancel [A2])
  :Confirm cancel → redirect to list;
  stop
else (Save Draft / Publish)
endif

:Validate required fields;

if (Valid?) then (No)
  split
    :Missing nameVi or lat/lng [E1];
  split again
    :Invalid coordinates [E2];
  end split
  :Return to fix form;
  kill
else (Yes)
endif

if (Save as?) then (Draft)
  :Create POI record (status = DRAFT);
else (Publish)
  :Create POI record (status = ACTIVE);
endif

:Show "POI created successfully";
:Redirect to POI list;

stop

@enduml


