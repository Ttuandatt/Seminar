# Database (khớp với docker-compose.yml)
DATABASE_URL="postgresql://postgres:123@localhost:5432/seminar_gpstour?schema=public"

# JWT
JWT_SECRET="change-me-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="change-me-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# Upload
UPLOAD_DIR="./uploads"
MAX_IMAGE_SIZE=5242880
MAX_AUDIO_SIZE=52428800

# Email (Brevo API) — Để trống sẽ fallback log ra console
BREVO_API_KEY=
MAIL_FROM="GPS Tours <your-verified-email@example.com>"
ADMIN_URL="http://localhost:5173"
